##################
# Gitignore template
##################

# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

###########################
# Repo additions
###########################
# Pyarrow roundtrip testing
rust/pyarrow-roundtrip/*.arrow
rust/pyarrow-roundtrip/*.stream
rust/pyarrow-roundtrip/__pycache__/
rust/pyarrow-roundtrip/.venv/
# python pytest suite
python/tests/__pycache__/
python/examples/**/__pycache__/
python/.pytest_cache/
.vscode/

# Cross-host benchmark rigs - result captures, terraform provider downloads
# and state. The .terraform.lock.hcl files are committed so a reproduction
# resolves the same pinned providers.
rust/benches/aws/results*
rust/benches/aws/terraform/.terraform/
rust/benches/aws/terraform/terraform.tfstate
rust/benches/aws/terraform/terraform.tfstate.backup
rust/benches/ecs/results/
rust/benches/ecs/terraform/.terraform/
rust/benches/ecs/terraform/terraform.tfstate
rust/benches/ecs/terraform/terraform.tfstate.backup

rust/.cargo

# agents
.claude/
.codex/
